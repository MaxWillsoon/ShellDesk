# Copy this file to .env and replace the placeholder values with local test credentials.

SHELLDESK_TEST_SSH_HOST=192.0.2.10
SHELLDESK_TEST_SSH_PORT=22
SHELLDESK_TEST_SSH_USERNAME=test-user
SHELLDESK_TEST_SSH_PASSWORD=change-me
# Optional: prefer key-based live smoke tests when available.
SHELLDESK_TEST_SSH_KEY_PATH=
SHELLDESK_TEST_SSH_KNOWN_HOSTS_PATH=
# After copying this file to .env, run pnpm smoke:ssh-live for explicit Rust
# SSH command, remote file, and SFTP probe live smoke coverage.

# Tauri updater signing is required for release builds that produce update artifacts.
# Generate keys with: pnpm tauri signer generate -- -w ~/.tauri/shelldesk.key
TAURI_SIGNING_PRIVATE_KEY=Path or content of your private key
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
# Public key generated with the updater signing key. This is embedded into the app so
# the runtime updater can verify latest.json artifacts before installing them.
TAURI_UPDATER_PUBLIC_KEY=
