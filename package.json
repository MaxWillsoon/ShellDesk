{
  "name": "shelldesk",
  "productName": "ShellDesk",
  "version": "1.0.0",
  "packageManager": "pnpm@11.8.0",
  "private": true,
  "description": "Tauri shell for a GUI SSH client.",
  "homepage": "https://github.com/liubaicai/ShellDesk",
  "author": "liubaicai <liushuai.baicai@hotmail.com>",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "check:contracts": "node scripts/check-ipc-parity.cjs && node scripts/check-desktop-app-contract.cjs && node scripts/check-i18n-contract.cjs && node scripts/check-runtime-boundary.cjs && node scripts/check-tauri-contract.cjs && node scripts/check-default-settings-parity.cjs && node scripts/test-release-scripts.cjs",
    "check:desktop-apps": "node scripts/check-desktop-app-contract.cjs",
    "check:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings && cargo test --manifest-path src-tauri/Cargo.toml",
    "check:rust:coverage": "node scripts/check-rust-coverage.cjs",
    "check:ui": "playwright test",
    "smoke:tauri-dev": "node scripts/check-tauri-dev-start.cjs",
    "smoke:ssh-live": "node scripts/check-live-ssh-smoke.cjs",
    "smoke:windows-host": "node scripts/check-live-host-components.cjs windows",
    "smoke:linux-host": "node scripts/check-live-host-components.cjs linux",
    "typecheck": "tsc --noEmit",
    "build": "pnpm typecheck && vite build",
    "test": "pnpm check:contracts && pnpm build && pnpm check:ui && pnpm check:rust && cargo check --manifest-path src-tauri/Cargo.toml",
    "tag": "node scripts/create-version-tag.cjs",
    "version:sync": "node scripts/set-release-version.cjs",
    "release:updater-manifest": "node .github/scripts/generate-tauri-updater-manifest.js",
    "release": "node scripts/run-tauri-build.cjs --target x86_64-pc-windows-msvc",
    "pack": "node scripts/run-tauri-build.cjs",
    "pack:dir": "node scripts/run-tauri-build.cjs --debug",
    "pack:win-x64": "node scripts/run-tauri-build.cjs --target x86_64-pc-windows-msvc",
    "pack:win-arm64": "node scripts/run-tauri-build.cjs --target aarch64-pc-windows-msvc",
    "pack:mac": "node scripts/run-tauri-build.cjs --bundles dmg,app",
    "pack:linux": "node scripts/run-tauri-build.cjs --bundles appimage,deb,rpm",
    "pack:linux-x64": "node scripts/run-tauri-build.cjs --target x86_64-unknown-linux-gnu --bundles appimage,deb,rpm",
    "pack:linux-arm64": "node scripts/run-tauri-build.cjs --target aarch64-unknown-linux-gnu --bundles appimage,deb,rpm",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@earendil-works/pi-agent-core": "^0.80.2",
    "@earendil-works/pi-ai": "^0.80.2",
    "@novnc/novnc": "^1.7.0",
    "@tauri-apps/api": "^2.9.0",
    "@uiw/react-codemirror": "^4.25.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode-graphemes": "0.4.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zmodem.js": "^0.1.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.9.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "sass": "^1.99.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.2"
  }
}
